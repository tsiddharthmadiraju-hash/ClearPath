# ClearPath backend configuration
#
# Leave ANTHROPIC_API_KEY unset to run in MOCK mode (full UX, no key needed).
# Set it to call Claude for real.

# --- Claude (live mode) ---
ANTHROPIC_API_KEY=your_key_here
# CLEARPATH_MODEL=claude-sonnet-4-6      # the plan's choice; override if you like
# CLEARPATH_MOCK=1                       # force mock mode even with a key set

# --- Server ---
PORT=4000
NODE_ENV=development
# FRONTEND_URL=https://your-deployed-frontend.example.com   # extra allowed CORS origin

# --- Optional anonymous logging (Supabase) ---
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_KEY=...
# SUPABASE_TABLE=sessions
